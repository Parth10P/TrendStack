{
  "expo": {
    "name": "trend_stack",
    "slug": "trend_stack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/trendStack_logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/trendStack_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/trendStack_logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "trend_stack.com"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "TrendStack needs photo access so you can upload media in your posts.",
          "cameraPermission": "TrendStack needs camera access so you can capture media for your posts.",
          "microphonePermission": false
        }
      ]
    ],
    "web": {
      "favicon": "./assets/trendStack_logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "2d129f38-5953-4ce3-a44b-9849f9a35163"
      }
    }
  }
}
